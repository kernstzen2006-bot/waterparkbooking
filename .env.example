# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# App
# Local dev can stay on localhost. On Vercel, set APP_BASE_URL and NEXT_PUBLIC_APP_URL to your real public site URL.
APP_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_NAME="Your Waterpark"
VENUE_NAME="Your Waterpark"
SUPPORT_EMAIL="support@yourwaterpark.co.za"

# Security
# Generate with: openssl rand -base64 32
JWT_SECRET=
QR_HMAC_SECRET="change_me_to_very_long_random"
WEBHOOK_HMAC_SECRET="optional_provider_secret_for_webhooks"

# Email
EMAIL_PROVIDER="smtp"
EMAIL_FROM="Your Waterpark <tickets@yourwaterpark.co.za>"

# SMTP
SMTP_HOST="smtp.yourprovider.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="smtp_username"
SMTP_PASS="smtp_password"

# Resend (alternative)
RESEND_API_KEY="re_..."

# Storage (Supabase Storage)
SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="service_role_key_here"
SUPABASE_STORAGE_BUCKET="waterpark"

# Payment (generic "mock" / provider integration you'll wire)
PAYMENT_PROVIDER="mock"
